# --- Server ---
PORT=8080
DATA_DIR=./data
ALLOWED_ORIGIN=http://localhost:3000

# --- Auth (required) ---
# Any long random string. Change this — sessions are signed with it.
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated invite codes. Friends need one to register. Empty = open signup.
INVITE_CODES=friends2026

# --- AI (optional) ---
# Without this, discovery + scoring still work; application drafting is disabled.
ANTHROPIC_API_KEY=
JOBSCOUT_MODEL=claude-haiku-4-5-20251001
# Per-user daily limit on AI drafts (protects a shared key).
DAILY_LLM_CAP=25

# --- Email digest (optional, off by default) ---
RESEND_API_KEY=
DIGEST_TO=
DIGEST_FROM=JobScout <onboarding@resend.dev>
